# ─── Firebase Client SDK (web app) ───────────────────────────────────────────
# Copy this file to .env.local and fill in your project values.
# Found in: Firebase Console → Project Settings → General → Your apps → SDK setup

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Firebase Admin SDK (seed script only) ───────────────────────────────────
# Required to run:  npm run db:seed
#
# Option A (recommended): Download a service account JSON key from:
#   Firebase Console → Project Settings → Service Accounts → Generate New Private Key
#   Save the file as  serviceAccount.json  in the project root (it is gitignored).
#
# Option B: Paste the full JSON value of the key file here (for CI/CD):
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
#
# Option C: Set this to the absolute path of your service account JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json
